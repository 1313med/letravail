# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/letravail?schema=public"

# Redis (BullMQ)
REDIS_URL="redis://localhost:6379"

# Scraper settings
MAX_CONCURRENT_SOURCES=5
PAGE_POOL_SIZE=3
BROWSER_HEADLESS=true
SCRAPE_TIMEOUT_MS=60000

# Logging
LOG_LEVEL=info
NODE_ENV=development

# LinkedIn (separate scrape — not included in scrape --all)
LINKEDIN_STORAGE_STATE=./linkedin-auth.json
LINKEDIN_MAX_JOBS=150
LINKEDIN_DELAY_MS=2000
LINKEDIN_SCROLL_ROUNDS=8
LINKEDIN_MAX_PAGES=10
LINKEDIN_DETAIL_FETCH_LIMIT=150
LINKEDIN_DETAIL_FETCH_ALL=true
LINKEDIN_PAGE_TIMEOUT_MS=25000

# Detail page fetching (CIH, Attijariwafa, DXC, generic scrapers)
DETAIL_FETCH_LIMIT=500
DETAIL_FETCH_DELAY_MS=400

# LinkedIn Employer Discovery Engine (Sprint 1)
LINKEDIN_DISCOVERY_ENABLED=true
LINKEDIN_DISCOVERY_ONBOARD_LIMIT=5
LINKEDIN_COMPANY_FETCH_LIMIT=25
# Time filter: omit or "all" = all jobs. r604800=7 days, r2592000=30 days
# LINKEDIN_TIME_FILTER=r604800
# BROWSER_HEADLESS=false
# LINKEDIN_FAST=true
# LINKEDIN_CITIES=Casablanca,Rabat,Marrakech
