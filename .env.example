# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/letravail?schema=public"

# Redis (BullMQ)
REDIS_URL="redis://localhost:6379"

# Scraper settings
MAX_CONCURRENT_SOURCES=5
PAGE_POOL_SIZE=3
BROWSER_HEADLESS=true
SCRAPE_TIMEOUT_MS=60000

# Logging
LOG_LEVEL=info
NODE_ENV=development
