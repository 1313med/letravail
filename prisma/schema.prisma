generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Scraper-owned models (PascalCase + @@map) ───────────────────────────────

model Job {
  id             String    @id @default(cuid())
  source         String
  sourceJobId    String
  hash           String    @unique
  slug           String    @unique
  title          String
  company        String
  city           String
  country        String    @default("Morocco")
  description    String    @db.Text
  requirements   String?   @db.Text
  salary         String?
  contractType   String?
  remote         Boolean   @default(false)
  applicationUrl String
  publishedAt    DateTime?
  expiresAt      DateTime?
  firstSeenAt    DateTime  @default(now())
  lastSeenAt     DateTime  @default(now())
  lastVerifiedAt DateTime?
  lastModifiedAt DateTime?
  sourcePublishedAt DateTime?
  crawlCount     Int       @default(0)
  isActive       Boolean   @default(true)
  archivedAt     DateTime?
  validationStatus String? @default("valid")
  validationFlags  String[] @default([])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Employment intelligence
  rawHtml            String? @db.Text
  extractionMetadata Json?
  experienceLevel    String?
  experienceYears    String?
  educationLevel     String?
  salaryMin          Int?
  salaryMax          Int?
  salaryCurrency     String?
  salaryPeriod       String?
  salaryNet          Boolean?
  qualityScore       Float?
  descriptionScore   Float?
  contentHash        String?

  companyId  String?
  locationId String?
  companyRef Company?  @relation(fields: [companyId], references: [id])
  location   Location? @relation(fields: [locationId], references: [id])
  tags       JobTag[]
  skills     JobSkill[]
  versions   JobVersion[]

  @@unique([source, sourceJobId])
  @@index([slug])
  @@index([title])
  @@index([company])
  @@index([city])
  @@index([publishedAt])
  @@index([source])
  @@index([hash])
  @@index([experienceLevel])
  @@index([educationLevel])
  @@index([qualityScore])
  @@index([lastSeenAt])
  @@index([isActive, publishedAt])
  @@index([contentHash])
  @@index([isActive, lastSeenAt])
  @@map("jobs")
}

model JobVersion {
  id           String   @id @default(cuid())
  jobId        String
  contentHash  String
  title        String
  description  String   @db.Text
  requirements String?  @db.Text
  rawHtml      String?  @db.Text
  capturedAt   DateTime @default(now())
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([contentHash])
  @@map("job_versions")
}

model Company {
  id            String   @id @default(cuid())
  name          String   @unique
  slug          String   @unique
  logoUrl       String?
  websiteUrl    String?
  industry      String?
  size          String?
  careerPageUrl String?
  linkedinUrl   String?
  headquartersCity String?
  sector        String?
  description   String?   @db.Text
  canonicalName String?
  resolutionConfidence Float?
  ownershipType String?
  foundedYear   Int?
  moroccanOffices String[] @default([])
  firstSeenAt   DateTime?
  lastCrawlAt   DateTime?
  activeJobCount Int       @default(0)
  archivedJobCount Int     @default(0)
  hiringFrequency String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  jobs          Job[]
  aliases       CompanyAlias[]
  discoveries   EmployerDiscovery[]

  @@index([slug])
  @@index([name])
  @@index([canonicalName])
  @@index([linkedinUrl])
  @@map("companies")
}

model EmployerDiscovery {
  id               String    @id @default(cuid())
  companyName      String
  normalizedName   String
  linkedinUrl      String?
  linkedinSlug     String?
  industry         String?
  headquarters     String?
  location         String?
  companySize      String?
  logoUrl          String?
  description      String?   @db.Text
  websiteUrl       String?
  careersUrl       String?
  hiringStatus     String    @default("unknown")
  discoverySource  String
  discoveredAt     DateTime  @default(now())
  lastSeenAt       DateTime  @default(now())
  jobCountSeen     Int       @default(1)
  onboardingStatus String    @default("discovered")
  recommendedSourceName String?
  sourceName       String?
  companyId        String?
  atsPlatform      String?
  probeConfidence  Float?
  metadata         Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  company          Company?  @relation(fields: [companyId], references: [id])

  @@unique([normalizedName])
  @@unique([linkedinSlug])
  @@index([companyName])
  @@index([onboardingStatus])
  @@index([discoveredAt])
  @@index([lastSeenAt])
  @@index([hiringStatus])
  @@map("employer_discoveries")
}

model CompanyAlias {
  id         String   @id @default(cuid())
  alias      String   @unique
  companyId  String
  confidence Float    @default(1)
  isManual   Boolean  @default(false)
  createdAt  DateTime @default(now())
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("company_aliases")
}

model SourceProfile {
  id                   String    @id @default(cuid())
  sourceName           String    @unique
  category             String
  companyName          String
  status               String    @default("active")
  crawlIntervalMinutes Int       @default(360)
  lastCrawlAt          DateTime?
  nextCrawlAt          DateTime?
  atsPlatform          String?
  careerPageUrl        String?
  probeConfidence      Float?
  crawlStrategy        String?
  lastProbedAt         DateTime?
  jsRenderingRequired  Boolean   @default(false)
  priorityScore        Float?
  activationState      String    @default("active")
  healthScore          Float?
  lastHealthUpdate     DateTime?
  intelligenceScore    Float?
  freshnessScore       Float?
  jobsDiscovered       Int       @default(0)
  activeJobs           Int       @default(0)
  archivedJobs         Int       @default(0)
  avgDescriptionLength Int?
  skillCoverage        Float?
  experienceCoverage   Float?
  avgCrawlDurationMs   Int?
  failureRate          Float?
  duplicateRate        Float?
  avgDailyAdditions    Float?
  avgDailyRemovals     Float?
  lastValidationReport Json?
  metadata             Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([status])
  @@index([nextCrawlAt])
  @@index([intelligenceScore])
  @@index([priorityScore])
  @@index([activationState])
  @@index([healthScore])
  @@map("source_profiles")
}

model EmployerAtsIntelligence {
  id                    String   @id @default(cuid())
  sourceName            String?
  companyName           String
  inputUrl              String
  careersPageUrl        String?
  finalUrl              String?
  atsPlatform           String
  confidence            Float
  crawlStrategy         String
  recommendedAdapter    String?
  apiEndpoints          String[] @default([])
  platformConfig        Json?
  robotsAllowed         Boolean  @default(true)
  sitemapUrls           String[] @default([])
  jsRenderingRequired   Boolean  @default(false)
  paginationType        String?
  detailEndpoint        String?
  applicationUrlPattern String?
  authRequired          Boolean  @default(false)
  estimatedJobVolume    String?
  technicalComplexity   String?
  maintenanceEffort     String?
  graphqlDetected       Boolean  @default(false)
  structuredData        Boolean  @default(false)
  issues                String[] @default([])
  investigationReasons  String[] @default([])
  onboardingStatus      String   @default("probed")
  activationState       String   @default("PROBED")
  healthScore           Float?
  validationScore       Float?
  lastValidationAt      DateTime?
  lastHealthCheck       DateTime?
  activationReason      String?
  deactivationReason    String?
  automaticActivation   Boolean  @default(false)
  retryCount            Int      @default(0)
  nextRetryAt           DateTime?
  validationSummary     Json?
  probedAt              DateTime @default(now())
  probeVersion          Int      @default(1)
  rawProbe              Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([sourceName])
  @@index([companyName])
  @@index([atsPlatform])
  @@index([confidence])
  @@index([probedAt])
  @@index([onboardingStatus])
  @@index([activationState])
  @@index([healthScore])
  @@index([nextRetryAt])
  @@map("employer_ats_intelligence")
}

/// Platform-level ATS mastery — one row per ATS, static profile + live metrics.
model AtsPlatformIntelligence {
  platform                String   @id
  displayName             String
  priority                Int      @default(50)
  detectionConfidence     Float    @default(70)
  authRequired            Boolean  @default(false)
  paginationStrategy      String?
  apiEndpointPattern      String?
  networkRequestHints     String[] @default([])
  detailPageStrategy      String?
  rateLimitPerMinute      Int?
  knownIssues             String[] @default([])
  domStructureHints       String[] @default([])
  robotsPolicy            String?
  playwrightRequired      Boolean  @default(false)
  adapterModule           String?
  employerCount           Int      @default(0)
  activeEmployerCount     Int      @default(0)
  probedEmployerCount     Int      @default(0)
  jobsCaptured            Int      @default(0)
  crawlAttempts           Int      @default(0)
  crawlSuccesses          Int      @default(0)
  successRate             Float?
  failureRate             Float?
  avgCrawlDurationMs    Int?
  avgDescriptionQuality   Float?
  avgEntityExtraction     Float?
  historicalSuccessRate   Float?
  estimatedEmployers      Int      @default(0)
  estimatedJobsUnlockable Int      @default(0)
  avgQualityScore         Float?
  roiScore                Float?
  lastMetricsAt           DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([priority])
  @@index([roiScore])
  @@map("ats_platform_intelligence")
}

model Location {
  id            String   @id @default(cuid())
  city          String
  country       String   @default("Morocco")
  region        String?
  canonicalCity String?
  slug          String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  jobs          Job[]

  @@unique([city, country])
  @@index([city])
  @@index([slug])
  @@index([region])
  @@map("locations")
}

model Skill {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  category  String?
  createdAt DateTime @default(now())
  jobs      JobSkill[]
  professions ProfessionSkill[]

  @@index([slug])
  @@index([name])
  @@index([category])
  @@map("skills")
}

model JobSkill {
  jobId      String
  skillId    String
  confidence Float?
  job        Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skill      Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([jobId, skillId])
  @@map("job_skills")
}

model ProfessionSkill {
  profession String
  skillId    String
  jobCount   Int      @default(0)
  updatedAt  DateTime @updatedAt
  skill      Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([profession, skillId])
  @@index([profession])
  @@map("profession_skills")
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  jobs      JobTag[]

  @@index([slug])
  @@index([name])
  @@map("tags")
}

model JobTag {
  jobId String
  tagId String
  job   Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  tag   Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([jobId, tagId])
  @@map("job_tags")
}

model ScrapeLog {
  id            String   @id @default(cuid())
  source        String
  category      String
  status        String
  startedAt     DateTime
  endedAt       DateTime?
  durationMs    Int?
  jobsFound     Int      @default(0)
  jobsInserted  Int      @default(0)
  jobsUpdated   Int      @default(0)
  duplicates    Int      @default(0)
  errorMessage  String?  @db.Text
  createdAt     DateTime @default(now())

  @@index([source])
  @@index([category])
  @@index([startedAt])
  @@index([status])
  @@map("scrape_logs")
}

// ─── Website-owned models (read-only from scraper perspective) ───────────────

model Profession {
  id           String   @id
  slug         String   @unique
  name         String
  aliases      String[] @default([])
  sectorSlug   String?
  skills       String[] @default([])
  salarySlug   String?
  relatedSlugs String[] @default([])
  keywords     String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime

  @@index([salarySlug])
  @@index([sectorSlug])
  @@map("professions")
}

model SalaryObservation {
  id           String   @id
  jobId        String
  titleNorm    String
  citySlug     String?
  sectorSlug   String?
  salaryMin      Int?
  salaryMax      Int?
  currency     String   @default("MAD")
  contractType String?
  observedAt   DateTime @default(now())
  source       String   @default("scraped")

  @@index([jobId])
  @@index([sectorSlug, observedAt])
  @@index([titleNorm, citySlug])
  @@map("salary_observations")
}

model GscPageMetric {
  id          String   @id
  pagePath    String
  pageType    String
  query       String   @default("")
  impressions Int      @default(0)
  clicks      Int      @default(0)
  ctr         Float    @default(0)
  position    Float    @default(0)
  periodStart DateTime
  periodEnd   DateTime
  ingestedAt  DateTime @default(now())

  @@unique([pagePath, query, periodStart, periodEnd])
  @@index([pagePath])
  @@index([periodEnd])
  @@map("gsc_page_metrics")
}

model GscQueryMetric {
  id          String   @id
  query       String
  pagePath    String   @default("")
  impressions Int      @default(0)
  clicks      Int      @default(0)
  ctr         Float    @default(0)
  position    Float    @default(0)
  periodStart DateTime
  periodEnd   DateTime
  ingestedAt  DateTime @default(now())

  @@unique([query, pagePath, periodStart, periodEnd])
  @@index([query])
  @@map("gsc_query_metrics")
}

model JobTitleTaxonomy {
  id         String   @id
  slug       String   @unique
  label      String
  parentSlug String?
  sectorSlug String?
  keywords   String[] @default([])
  createdAt  DateTime @default(now())

  @@index([sectorSlug])
  @@map("job_title_taxonomy")
}

model MarketSnapshot {
  id           String   @id
  weekStart    DateTime
  citySlug     String?
  sectorSlug   String?
  jobCount     Int
  medianSalary Int?
  topSkills    Json     @default("[]")
  topCompanies Json     @default("[]")

  @@unique([weekStart, citySlug, sectorSlug])
  @@index([weekStart])
  @@map("market_snapshots")
}

model SeoActionLog {
  id        String   @id
  action    String
  status    String
  message   String
  details   Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([action])
  @@index([createdAt])
  @@map("seo_action_logs")
}

model SerpIntelligenceRecord {
  id                 String    @id
  provider           String
  keyword            String
  pagePath           String?
  ourPosition        Float?
  competitorDomain   String?
  competitorPosition Float?
  searchVolume       Int?
  capturedAt         DateTime  @default(now())
  periodStart        DateTime?
  periodEnd          DateTime?
  raw                Json      @default("{}")

  @@index([capturedAt])
  @@index([keyword])
  @@index([provider])
  @@map("serp_intelligence_records")
}

model Subscriber {
  id         String   @id
  email      String   @unique
  citySlug   String?
  sectorSlug String?
  source     String   @default("website")
  createdAt  DateTime @default(now())

  @@index([citySlug])
  @@index([sectorSlug])
  @@map("subscribers")
}
